local function lerpAngle(current, target, alpha)
	return current + (target - current) * alpha
end

local function getTargetPart(character, hitboxMode)
	if hitboxMode == 1 then
		return character:FindFirstChild("Head")
	elseif hitboxMode == 2 then
		return character:FindFirstChild("HumanoidRootPart")
	else
		-- "Nearest": whichever part (Head or HRP) is closer to screen center
		local head = character:FindFirstChild("Head")
		local hrp  = character:FindFirstChild("HumanoidRootPart")
		return head or hrp
	end
end

local function getClosestTargetInFOV(fovRadius)
	local myChar = player.Character
	if not myChar then return nil end
	local myHRP = myChar:FindFirstChild("HumanoidRootPart")
	if not myHRP then return nil end

	-- WorldToViewportPoint returns raw screen coords (includes inset),
	-- so compare against raw mouse position here (no inset subtraction)
	local mouse   = UserInputService:GetMouseLocation()
	local mx, my  = mouse.X, mouse.Y
	local best, bestDist = nil, math.huge

	for _, p in ipairs(game.Players:GetPlayers()) do
		if p ~= player and p.Character then
			local hum = p.Character:FindFirstChild("Humanoid")
			if hum and hum.Health > 0 then
				local part = getTargetPart(p.Character, targetSeg.getSelected())
				if part then
					local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
					if onScreen then
						local dx = screenPos.X - mx
						local dy = screenPos.Y - my
						local dist2D = math.sqrt(dx*dx + dy*dy)
						if dist2D <= fovRadius and dist2D < bestDist then
							bestDist = dist2D
							best = part
						end
					end
				end
			end
		end
	end
	return best
end


