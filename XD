RunService.RenderStepped:Connect(function()
	-- ── FOV circle: follows mouse, mouse is at exact center ──
	local radius = fovRadiusSlider.getValue()
	local mouse  = UserInputService:GetMouseLocation()
	local inset  = GuiService:GetGuiInset()

	-- GetMouseLocation includes the top inset bar; subtract it so the
	-- circle position matches the ScreenGui coordinate space exactly
	local mx = mouse.X - inset.X
	local my = mouse.Y - inset.Y

	fovCircle.Position = UDim2.new(0, mx, 0, my)
	fovCircle.Size     = UDim2.new(0, radius * 2, 0, radius * 2)

	-- ── Aimbot ───────────────────────────────────────────────
	if aimbotEnabled and aimHolding then
		local target = getClosestTargetInFOV(radius)
		if target then
			local smooth  = smoothSlider.getValue()
			local sens    = sensSlider.getValue() / 10
			local targetSP, onScreen = Camera:WorldToViewportPoint(target.Position)
			if onScreen then
				-- Convert screen target to a world CFrame the camera should look at
				local currentCF = Camera.CFrame
				local targetWorld = target.Position
				local lookCF = CFrame.lookAt(currentCF.Position, targetWorld)
				-- Smooth interpolation toward target
				local alpha = math.clamp(sens / smooth, 0.01, 1)
				Camera.CFrame = currentCF:Lerp(lookCF, alpha)
			end
		end
	end


	if not espEnabled and not chamsEnabled then return end

	local myHRP = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
	local fillAlpha = chamsAlphaSlider.getValue()
	local isNeon = chamStyleSeg.getSelected() == 2

	for p, data in pairs(espData) do
		if data.highlight and data.highlight.Parent then

			if espEnabled then
				data.highlight.OutlineTransparency = 0
			else
				data.highlight.OutlineTransparency = 1
			end

			if chamsEnabled then
				local fillTransparency = 1 - fillAlpha
				data.highlight.FillTransparency = fillTransparency

				if isNeon then
					data.highlight.FillColor = data.color
					data.highlight.OutlineColor = Color3.new(1, 1, 1)
				else
					data.highlight.FillColor = data.color
					data.highlight.OutlineColor = data.color
				end
			else
				data.highlight.FillTransparency = 1
			end

			if data.billboard and data.billboard.Parent then
				data.billboard.Enabled = espEnabled

				if espEnabled and myHRP then
					local theirHRP = p.Character and p.Character:FindFirstChild("HumanoidRootPart")
					if theirHRP then
						local dist = math.floor((myHRP.Position - theirHRP.Position).Magnitude)
						local distLabel = data.billboard:FindFirstChild("DistLabel")
						if distLabel then
							distLabel.Text = dist .. " m"
						end
					end
				end
			end
		end
	end
end)
