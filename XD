	distLbl.TextColor3 = Color3.fromRGB(200, 210, 255)
	distLbl.Font = Enum.Font.Gotham
	distLbl.TextSize = 11
	distLbl.TextStrokeTransparency = 0.5
	distLbl.TextStrokeColor3 = Color3.new(0, 0, 0)
	distLbl.Parent = billboard

	espData[targetPlayer] = {
