local function createSlider(parent, posY, label, minVal, maxVal, default, unit, decimals)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 0, 52)
	container.Position = UDim2.new(0, 0, 0, posY)
	container.BackgroundTransparency = 1
	container.Parent = parent

	local row = Instance.new("Frame")
	row.Size = UDim2.new(1, 0, 0, 18)
	row.BackgroundTransparency = 1
	row.Parent = container

	local lbl = Instance.new("TextLabel")
	lbl.Size = UDim2.new(0.5, 0, 1, 0)
	lbl.BackgroundTransparency = 1
	lbl.Text = label
	lbl.TextColor3 = Color3.fromRGB(139, 151, 192)
	lbl.Font = Enum.Font.Gotham
	lbl.TextSize = 12
	lbl.TextXAlignment = Enum.TextXAlignment.Left
	lbl.Parent = row

	local valLbl = Instance.new("TextLabel")
	valLbl.Size = UDim2.new(0.5, 0, 1, 0)
	valLbl.Position = UDim2.new(0.5, 0, 0, 0)
	valLbl.BackgroundTransparency = 1
	valLbl.Text = tostring(default) .. unit
	valLbl.TextColor3 = Color3.fromRGB(91, 157, 255)
	valLbl.Font = Enum.Font.GothamBold
	valLbl.TextSize = 13
	valLbl.TextXAlignment = Enum.TextXAlignment.Right
	valLbl.Parent = row

	local track = Instance.new("Frame")
	track.Size = UDim2.new(1, 0, 0, 6)
	track.Position = UDim2.new(0, 0, 0, 26)
	track.BackgroundColor3 = Color3.fromRGB(28, 39, 64)
	track.BorderSizePixel = 0
	track.Parent = container

	local trackCorner = Instance.new("UICorner")
	trackCorner.CornerRadius = UDim.new(1, 0)
	trackCorner.Parent = track

	local initAlpha = (default - minVal) / (maxVal - minVal)

	local fill = Instance.new("Frame")
	fill.Size = UDim2.new(initAlpha, 0, 1, 0)
	fill.BackgroundColor3 = Color3.fromRGB(58, 95, 200)
	fill.BorderSizePixel = 0
	fill.Parent = track

	local fillCorner = Instance.new("UICorner")
	fillCorner.CornerRadius = UDim.new(1, 0)
	fillCorner.Parent = fill

	local knob = Instance.new("Frame")
	knob.Size = UDim2.new(0, 16, 0, 16)
	knob.AnchorPoint = Vector2.new(0.5, 0.5)
	knob.Position = UDim2.new(initAlpha, 0, 0.5, 0)
	knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	knob.ZIndex = 2
	knob.Parent = track

	local knobCorner = Instance.new("UICorner")
	knobCorner.CornerRadius = UDim.new(1, 0)
	knobCorner.Parent = knob

	local knobStroke = Instance.new("UIStroke")
	knobStroke.Color = Color3.fromRGB(91, 157, 255)
	knobStroke.Thickness = 2
	knobStroke.Parent = knob

	local currentValue = default
	local sliderDragging = false

	local function update(inputPos)
		local trackPos = track.AbsolutePosition.X
		local trackSize = track.AbsoluteSize.X
		local relative = math.clamp((inputPos.X - trackPos) / trackSize, 0, 1)
		local raw = minVal + relative * (maxVal - minVal)
		if decimals and decimals > 0 then
			local mult = 10 ^ decimals
			currentValue = math.floor(raw * mult + 0.5) / mult
		else
			currentValue = math.floor(raw + 0.5)
		end
		fill.Size = UDim2.new(relative, 0, 1, 0)
		knob.Position = UDim2.new(relative, 0, 0.5, 0)
		valLbl.Text = tostring(currentValue) .. unit
	end

	track.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = true
			update(input.Position)
		end
	end)
	knob.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = true
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if sliderDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			update(input.Position)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			sliderDragging = false
		end
	end)

	return {getValue = function() return currentValue end}
end


local function createSegmented(parent, posY, optionsList, onChange)
	local container = Instance.new("Frame")
	container.Size = UDim2.new(1, 0, 0, 30)
	container.Position = UDim2.new(0, 0, 0, posY)
	container.BackgroundTransparency = 1
	container.Parent = parent

	local layout = Instance.new("UIListLayout")
	layout.FillDirection = Enum.FillDirection.Horizontal
	layout.Padding = UDim.new(0, 6)
	layout.Parent = container

	local selected = 1
	local segButtons = {}

	local function refresh()
		for i, seg in ipairs(segButtons) do
			if i == selected then
				seg.frame.BackgroundColor3 = Color3.fromRGB(28, 42, 77)
				seg.stroke.Color = Color3.fromRGB(58, 95, 200)
				seg.label.TextColor3 = Color3.fromRGB(174, 203, 255)
			else
				seg.frame.BackgroundColor3 = Color3.fromRGB(22, 29, 48)
				seg.stroke.Color = Color3.fromRGB(35, 45, 69)
				seg.label.TextColor3 = Color3.fromRGB(107, 122, 163)
			end
		end
	end

	local segWidth = (1 / #optionsList)

	for i, optName in ipairs(optionsList) do
		local seg = Instance.new("Frame")
		seg.Size = UDim2.new(segWidth, -4, 1, 0)
		seg.BackgroundColor3 = Color3.fromRGB(22, 29, 48)
		seg.Parent = container

		local segCorner = Instance.new("UICorner")
		segCorner.CornerRadius = UDim.new(0, 8)
		segCorner.Parent = seg

		local segStroke = Instance.new("UIStroke")
		segStroke.Color = Color3.fromRGB(35, 45, 69)
		segStroke.Thickness = 1
		segStroke.Parent = seg

		local lbl = Instance.new("TextLabel")
		lbl.Size = UDim2.new(1, 0, 1, 0)
		lbl.BackgroundTransparency = 1
		lbl.Text = optName
		lbl.TextColor3 = Color3.fromRGB(107, 122, 163)
		lbl.Font = Enum.Font.Gotham
		lbl.TextSize = 10
		lbl.TextScaled = false
		lbl.Parent = seg

		local clickBtn = Instance.new("TextButton")
		clickBtn.Size = UDim2.new(1, 0, 1, 0)
		clickBtn.BackgroundTransparency = 1
		clickBtn.Text = ""
		clickBtn.Parent = seg

		segButtons[i] = {frame = seg, stroke = segStroke, label = lbl}

		clickBtn.MouseButton1Click:Connect(function()
			selected = i
			refresh()
			if onChange then onChange(i) end
		end)
	end

	refresh()
	return {getSelected = function() return selected end}
end


