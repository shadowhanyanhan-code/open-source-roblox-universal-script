local function removeESP(targetPlayer)
	local data = espData[targetPlayer]
	if not data then return end
	if data.highlight and data.highlight.Parent then data.highlight:Destroy() end
	if data.billboard and data.billboard.Parent then data.billboard:Destroy() end
	espData[targetPlayer] = nil
end

local function clearAllESP()
	for p, _ in pairs(espData) do
		removeESP(p)
	end
end

local function initESP()
	for _, p in ipairs(game.Players:GetPlayers()) do
		if p ~= player and p.Character then
			attachESP(p, p.Character)
		end
	end
end

local function onPlayerAdded(p)
	if p == player then return end
	p.CharacterAdded:Connect(function(character)
		if espEnabled then
			task.wait()
			attachESP(p, character)
		end
	end)
	if espEnabled and p.Character then
		attachESP(p, p.Character)
	end
end

for _, p in ipairs(game.Players:GetPlayers()) do
	onPlayerAdded(p)
end
game.Players.PlayerAdded:Connect(onPlayerAdded)

game.Players.PlayerRemoving:Connect(function(p)
	removeESP(p)
end)

espToggle.clickBtn.MouseButton1Click:Connect(function()
	espEnabled = not espEnabled
	espToggle.setState(espEnabled)
	espToggle.setVisual(espEnabled)

	if espEnabled then
		initESP()
	else
		for _, data in pairs(espData) do
			if data.highlight and data.highlight.Parent then
				data.highlight.OutlineTransparency = 1
				data.highlight.FillTransparency = 1
			end
			if data.billboard and data.billboard.Parent then
				data.billboard.Enabled = false
			end
		end
		clearAllESP()
	end
end)

