local spinning = false
local spinConnection = nil

local function getDirectionMultiplier()
	return directionSeg.getSelected() == 1 and 1 or -1
end

applyPlatformStand = function(axisIndex)
	local character = player.Character
	if not character then return end
	local hum = character:FindFirstChild("Humanoid")
	if not hum then return end
	if spinning and axisIndex ~= 1 then
		hum.PlatformStand = true
	else
		hum.PlatformStand = false
	end
end

local function spinCharacter(character)
	local hrp = character:WaitForChild("HumanoidRootPart")
	local hum = character:WaitForChild("Humanoid")
	applyPlatformStand(axisSeg.getSelected())

	spinConnection = RunService.Heartbeat:Connect(function(dt)
		if not hrp or not hrp.Parent then
			if spinConnection then spinConnection:Disconnect() end
			if hum then hum.PlatformStand = false end
			return
		end
		local speed = speedSlider.getValue()
		local dir = getDirectionMultiplier()
		local axis = axisSeg.getSelected()
		local angle = math.rad(360) * dt * speed * dir

		if axis == 1 then
			hrp.CFrame = hrp.CFrame * CFrame.Angles(0, angle, 0)
		elseif axis == 2 then
			hrp.CFrame = hrp.CFrame * CFrame.Angles(angle, 0, 0)
		else
			hrp.CFrame = hrp.CFrame * CFrame.Angles(0, 0, angle)
		end
	end)
end

local function startSpin()
	local character = player.Character
	if character then spinCharacter(character) end
end

local function stopSpin()
	if spinConnection then
		spinConnection:Disconnect()
		spinConnection = nil
	end
	local character = player.Character
	if character then
		local hum = character:FindFirstChild("Humanoid")
		if hum then hum.PlatformStand = false end
	end
end

